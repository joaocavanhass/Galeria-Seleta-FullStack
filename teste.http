# =========================================
# Galeria Seleta — Testes completos de API
# Siga a ordem numérica para evitar erros
#
# COMO USAR:
#   1. Execute o teste #3 (login do usuário)
#   2. Execute o teste #3b (login do admin)
#   3. Os tokens são capturados automaticamente
#      e usados nos endpoints seguintes
# =========================================

@base = http://localhost:8080/api

# =========================================
# AUTH — AuthController + AuthService
# =========================================

### 1. Registrar usuário
POST {{base}}/auth/register
Content-Type: application/json

{
  "nome": "João Silva",
  "email": "joao@email.com",
  "senha": "123456",
  "telefone": "11999999999"
}

### 2. Registrar e-mail duplicado (deve retornar erro)
POST {{base}}/auth/register
Content-Type: application/json

{
  "nome": "Outro João",
  "email": "joao@email.com",
  "senha": "654321"
}

### 3. Login correto — token capturado automaticamente
# @name login
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "joao@email.com",
  "senha": "123456"
}

### 3b. Login admin — token capturado para operações administrativas
# @name adminLogin
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "admin@galeriaseleta.com",
  "senha": "admin123"
}

### 4. Login com senha errada (deve retornar erro)
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "joao@email.com",
  "senha": "senhaerrada"
}

### 5. Logout
POST {{base}}/auth/logout

### 6. Esqueceu a senha (verifica se e-mail existe)
POST {{base}}/auth/forgot-password
Content-Type: application/json

{
  "email": "joao@email.com"
}

### 7. Esqueceu a senha com e-mail inexistente (deve retornar erro)
POST {{base}}/auth/forgot-password
Content-Type: application/json

{
  "email": "naoexiste@email.com"
}

# =========================================
# USUÁRIO — UsuarioController + UsuarioService
# =========================================

### 8. Ver perfil
GET {{base}}/usuarios/me
Authorization: Bearer {{login.response.body.accessToken}}

### 9. Atualizar nome e telefone
PUT {{base}}/usuarios/me
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "nome": "João Atualizado",
  "telefone": "11888888888"
}

### 10. Alterar senha
PATCH {{base}}/usuarios/me/senha
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "senhaAtual": "123456",
  "novaSenha": "novaSenha123"
}

### 11. Adicionar endereço principal
POST {{base}}/usuarios/me/enderecos
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "rua": "Rua das Flores, 123",
  "cidade": "São Paulo",
  "estado": "SP",
  "cep": "01310-100",
  "principal": true
}

### 12. Adicionar segundo endereço
POST {{base}}/usuarios/me/enderecos
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "rua": "Av. Paulista, 1000",
  "cidade": "São Paulo",
  "estado": "SP",
  "cep": "01310-200",
  "principal": false
}

### 13. Listar endereços
GET {{base}}/usuarios/me/enderecos
Authorization: Bearer {{login.response.body.accessToken}}

### 14. Remover endereço
DELETE {{base}}/usuarios/me/enderecos/2
Authorization: Bearer {{login.response.body.accessToken}}

# =========================================
# CATEGORIAS — CategoriaController + CategoriaService
# =========================================

### 15. Criar categoria raiz
POST {{base}}/categorias
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Roupas",
  "nomeUrl": "roupas"
}

### 16. Criar subcategoria (categoriaMaeId = 1)
POST {{base}}/categorias
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Camisetas",
  "nomeUrl": "camisetas",
  "categoriaMaeId": 1
}

### 17. Listar todas as categorias
GET {{base}}/categorias

### 18. Buscar categoria por ID
GET {{base}}/categorias/1

### 19. Atualizar categoria
PUT {{base}}/categorias/2
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Camisetas Vintage",
  "nomeUrl": "camisetas-vintage"
}

### 20. Desativar categoria
PUT {{base}}/categorias/2
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "ativo": false
}

### 21. Deletar categoria
DELETE {{base}}/categorias/2
Authorization: Bearer {{adminLogin.response.body.accessToken}}

# =========================================
# PRODUTOS — ProdutoController + ProdutoService
# =========================================

### 22. Criar produto 1
POST {{base}}/produtos
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Camiseta Listrada",
  "descricao": "Camiseta vintage listrada anos 80",
  "preco": 59.90,
  "categoriaId": 1,
  "novidade": true,
  "status": "disponivel"
}

### 23. Criar produto 2
POST {{base}}/produtos
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Vestido Floral",
  "descricao": "Vestido estampado anos 70",
  "preco": 129.90,
  "categoriaId": 1,
  "novidade": false,
  "status": "disponivel"
}

### 24. Criar produto 3 (inativo)
POST {{base}}/produtos
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Calça Jeans",
  "descricao": "Jeans clássico desbotado",
  "preco": 89.90,
  "categoriaId": 1,
  "novidade": false,
  "status": "inativo"
}

### 25. Listar todos os produtos (ativos)
GET {{base}}/produtos

### 26. Listar todos incluindo inativos
GET {{base}}/produtos?status=todos

### 27. Listar por menor preço
GET {{base}}/produtos?ordenacao=menor-preco

### 28. Listar por maior preço
GET {{base}}/produtos?ordenacao=maior-preco

### 29. Listar novidades
GET {{base}}/produtos/novidades

### 30. Buscar por nome
GET {{base}}/produtos/busca?termo=camiseta

### 31. Buscar produto por ID
GET {{base}}/produtos/1

### 32. Listar produtos por categoria
GET {{base}}/categorias/1/produtos

### 33. Atualizar produto
PUT {{base}}/produtos/1
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "nome": "Camiseta Listrada Vintage",
  "preco": 69.90
}

### 34. Alterar status do produto
PATCH {{base}}/produtos/3/status
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "status": "disponivel"
}

### 35. Deletar produto
DELETE {{base}}/produtos/3
Authorization: Bearer {{adminLogin.response.body.accessToken}}

# =========================================
# CARRINHO — CarrinhoController + CarrinhoService
# =========================================

### 36. Ver carrinho (vazio)
GET {{base}}/carrinho
Authorization: Bearer {{login.response.body.accessToken}}

### 37. Adicionar produto 1 ao carrinho
POST {{base}}/carrinho/itens
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "produtoId": 1,
  "quantidade": 1
}

### 38. Adicionar produto 2 ao carrinho
POST {{base}}/carrinho/itens
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "produtoId": 2,
  "quantidade": 1
}

### 39. Adicionar produto já existente (não deve duplicar)
POST {{base}}/carrinho/itens
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "produtoId": 1,
  "quantidade": 1
}

### 40. Ver carrinho com itens
GET {{base}}/carrinho
Authorization: Bearer {{login.response.body.accessToken}}

### 41. Remover item do carrinho (id do item = 2)
DELETE {{base}}/carrinho/itens/2
Authorization: Bearer {{login.response.body.accessToken}}

### 42. Ver carrinho após remoção
GET {{base}}/carrinho
Authorization: Bearer {{login.response.body.accessToken}}

### 43. Limpar carrinho
DELETE {{base}}/carrinho
Authorization: Bearer {{login.response.body.accessToken}}

### 44. Ver carrinho após limpar (deve estar vazio)
GET {{base}}/carrinho
Authorization: Bearer {{login.response.body.accessToken}}

# =========================================
# PEDIDOS — PedidoController + PedidoService
# =========================================

### 45. Adicionar itens ao carrinho antes do pedido
POST {{base}}/carrinho/itens
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "produtoId": 1,
  "quantidade": 1
}

### 46. Criar pedido
POST {{base}}/pedidos
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "enderecoId": 1,
  "produtoIds": [1, 2]
}

### 47. Listar todos os pedidos
GET {{base}}/pedidos
Authorization: Bearer {{login.response.body.accessToken}}

### 48. Listar pedidos por status
GET {{base}}/pedidos?status=pendente
Authorization: Bearer {{login.response.body.accessToken}}

### 49. Buscar pedido por ID
GET {{base}}/pedidos/1
Authorization: Bearer {{login.response.body.accessToken}}

### 50. Atualizar status do pedido (admin)
PATCH {{base}}/pedidos/1/status
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.accessToken}}

{
  "status": "confirmado"
}

### 51. Cancelar pedido
PATCH {{base}}/pedidos/1/cancelar
Authorization: Bearer {{login.response.body.accessToken}}

### 52. Verificar status após cancelamento
GET {{base}}/pedidos/1
Authorization: Bearer {{login.response.body.accessToken}}

# =========================================
# CONTATO — ContatoController + ContatoService
# =========================================

### 53. Enviar mensagem de contato
POST {{base}}/contato
Content-Type: application/json

{
  "nome": "Maria",
  "sobrenome": "Santos",
  "email": "maria@email.com",
  "telefone": "11977777777",
  "mensagem": "Tenho interesse em peças dos anos 90, vocês têm?"
}

### 54. Inscrever na newsletter
POST {{base}}/newsletter/inscrever
Content-Type: application/json

{
  "email": "maria@email.com"
}

### 55. Inscrever mesmo e-mail (deve reativar, não duplicar)
POST {{base}}/newsletter/inscrever
Content-Type: application/json

{
  "email": "maria@email.com"
}

### 56. Cancelar inscrição na newsletter
DELETE {{base}}/newsletter/cancelar?email=maria@email.com
